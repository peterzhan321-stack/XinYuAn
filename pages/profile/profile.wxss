.container {
  padding: 30rpx;
  min-height: 100vh;
  background-color: #f5f7fa;
}
.user-info {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.avatar-section {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  margin-right: 30rpx;
}
.user-detail {
  flex: 1;
}
.username {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}
.user-id {
  font-size: 28rpx;
  color: #999;
}
.stats {
  display: flex;
  justify-content: space-around;
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}
.stat-item {
  text-align: center;
}
.stat-value {
  font-size: 44rpx;
  font-weight: bold;
  color: #4A90E2;
  display: block;
  margin-bottom: 10rpx;
}
.stat-label {
  font-size: 28rpx;
  color: #666;
}
.function-list {
  background: white;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.list-section {
  border-bottom: 1rpx solid #f0f0f0;
}
.list-section:last-child {
  border-bottom: none;
}
.section-title {
  font-size: 32rpx;
  color: #999;
  padding: 30rpx 30rpx 20rpx;
  background-color: #fafafa;
}
.list-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}
.list-item:active {
  background-color: #f9f9f9;
}
.item-icon {
  font-size: 40rpx;
  margin-right: 25rpx;
  width: 50rpx;
  text-align: center;
}
.item-text {
  font-size: 34rpx;
  color: #333;
  flex: 1;
}
.item-arrow {
  font-size: 50rpx;
  color: #ccc;
  margin-left: 20rpx;
}
.logout-section {
  padding: 0 30rpx;
}
.login-btn, .logout-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
  margin: 0;
}
.login-btn {
  background: linear-gradient(135deg, #4A90E2, #9b59b6);
  color: white;
}
.logout-btn {
  background-color: #f0f0f0;
  color: #666;
}