.records-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f7fa;
}
.search-filter-section {
  background: white;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 100;
}
.search-box {
  position: relative;
  margin-bottom: 20rpx;
}
.search-input {
  height: 80rpx;
  background-color: #f8f9fa;
  border-radius: 40rpx;
  padding: 0 80rpx 0 30rpx;
  font-size: 32rpx;
  border: 1rpx solid #e0e0e0;
}
.search-icon {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #999;
  font-size: 36rpx;
}
.filter-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}
.filter-picker {
  flex: 1;
}
.filter-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 70rpx;
  background-color: #f8f9fa;
  border-radius: 35rpx;
  padding: 0 25rpx;
  border: 1rpx solid #e0e0e0;
  font-size: 28rpx;
  color: #666;
}
.filter-item .arrow {
  color: #999;
  font-size: 24rpx;
}
.records-list {
  flex: 1;
  padding: 20rpx 30rpx 100rpx;
}
.stats-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  font-size: 28rpx;
  color: #666;
}
.action-buttons {
  display: flex;
  gap: 15rpx;
}
.action-btn {
  height: 50rpx;
  line-height: 50rpx;
  border-radius: 25rpx;
  font-size: 24rpx;
  padding: 0 20rpx;
  margin: 0;
}
.export-btn {
  background-color: #4A90E2;
  color: white;
}
.clear-btn {
  background-color: #ff4444;
  color: white;
}
.record-item {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 25rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}
.record-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.1);
}
.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.record-mood {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: white;
}
.record-time {
  font-size: 24rpx;
  color: #999;
}
.record-content {
  margin-bottom: 20rpx;
}
.content-text {
  font-size: 32rpx;
  line-height: 1.5;
  color: #333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}
.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}
.record-analysis {
  display: flex;
  gap: 15rpx;
  flex-wrap: wrap;
}
.analysis-tag {
  padding: 5rpx 15rpx;
  border-radius: 15rpx;
  font-size: 22rpx;
  background-color: #f0f0f0;
  color: #666;
}
.record-actions {
  display: flex;
  gap: 15rpx;
}
.icon-btn {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  width: 50rpx;
  height: 50rpx;
  font-size: 32rpx;
  line-height: 50rpx;
  text-align: center;
}
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}
.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
  opacity: 0.3;
}
.empty-text {
  font-size: 36rpx;
  color: #999;
  display: block;
  margin-bottom: 15rpx;
}
.empty-hint {
  font-size: 28rpx;
  color: #ccc;
  display: block;
  margin-bottom: 40rpx;
}
.loading-more, .no-more {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}