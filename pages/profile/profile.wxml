<view class="container">
  <view class="user-info">
    <view class="avatar-section">
      <image class="avatar" src="/images/avatar-default.png" />
      <view class="user-detail">
        <text class="username">{{userInfo.nickName || '心语安用户'}}</text>
        <text class="user-id">ID: {{userInfo.userId || '未登录'}}</text>
      </view>
    </view>
    <view class="stats">
      <view class="stat-item">
        <text class="stat-value">{{recordCount}}</text>
        <text class="stat-label">记录总数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{continuousDays}}</text>
        <text class="stat-label">连续记录</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{assessmentCount}}</text>
        <text class="stat-label">测评完成</text>
      </view>
    </view>
  </view>
  <view class="function-list">
    <view class="list-section">
      <view class="section-title">我的记录</view>
      <view class="list-item" bindtap="goToMyRecords">
        <text class="item-icon">📋</text>
        <text class="item-text">情绪记录历史</text>
        <text class="item-arrow">›</text>
      </view>
      <view class="list-item" bindtap="goToMyAssessments">
        <text class="item-icon">📊</text>
        <text class="item-text">测评报告</text>
        <text class="item-arrow">›</text>
      </view>
    </view>
    <view class="list-section">
      <view class="section-title">干预方案</view>
      <view class="list-item" bindtap="goToInterventions">
        <text class="item-icon">🧘</text>
        <text class="item-text">心理干预方案</text>
        <text class="item-arrow">›</text>
      </view>
      <view class="list-item" bindtap="goToEmergency">
        <text class="item-icon">🚨</text>
        <text class="item-text">紧急联系方式</text>
        <text class="item-arrow">›</text>
      </view>
    </view>
    <view class="list-section">
      <view class="section-title">设置</view>
      <view class="list-item" bindtap="goToSettings">
        <text class="item-icon">⚙️</text>
        <text class="item-text">应用设置</text>
        <text class="item-arrow">›</text>
      </view>
      <view class="list-item" bindtap="goToAbout">
        <text class="item-icon">ℹ️</text>
        <text class="item-text">关于我们</text>
        <text class="item-arrow">›</text>
      </view>
    </view>
  </view>
  <view class="logout-section">
    <button wx:if="{{isLoggedIn}}" class="logout-btn" bindtap="handleLogout">退出登录</button>
    <button wx:else class="login-btn" bindtap="handleLogin">登录/注册</button>
  </view>
</view>