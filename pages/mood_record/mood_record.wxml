<view>
  <view style="font-size: 40rpx; font-weight: bold; margin: 40rpx">记录心情</view>
  
  <view style="margin: 0 30rpx 40rpx">
    <text style="display: block; margin-bottom: 20rpx; color: #666">选择情绪标签：</text>
    <view style="display: flex; flex-wrap: wrap; gap: 20rpx">
      <block wx:for="{{moodOptions}}" wx:key="index">
        <view 
          style="padding: 15rpx 30rpx; border: 2rpx solid #4A90E2; border-radius: 50rpx; color: #4A90E2" 
          bindtap="selectMood" 
          data-mood="{{item}}"
        >
          {{item}}
        </view>
      </block>
    </view>
  </view>
  
  <view style="background: white; border-radius: 20rpx; padding: 30rpx; margin: 0 30rpx 40rpx">
    <textarea 
      placeholder="写下你想说的话吧..." 
      bindinput="onTextInput" 
      value="{{textContent}}"
      maxlength="500"
      style="width: 100%; min-height: 200rpx; font-size: 32rpx"
    />
    <text style="display: block; text-align: right; color: #999; font-size: 28rpx; margin-top: 20rpx">{{textContent.length}}/500</text>
  </view>

  <view style="background: white; border-radius: 20rpx; padding: 30rpx; margin: 0 30rpx 40rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05)">
    <view style="font-size: 34rpx; margin-bottom: 20rpx; color: #333">🎤 语音记录（可选）</view>
    <view style="display: flex; flex-direction: column; align-items: center; gap: 20rpx">
      <button 
        style="width: 70%; background-color: {{isRecording ? '#ff4444' : '#4A90E2'}}; color: white; border-radius: 50rpx; font-size: 32rpx; border: none"
        bindtap="handleRecord">
        {{isRecording ? '⏹️ 停止录音 (' + recordTime + 's)' : '🎤 开始录音'}}
      </button>
      
      <view wx:if="{{isRecording}}" style="font-size: 28rpx; color: #ff4444; text-align: center; padding: 10rpx 0">
        ⏺️ 录音中... 请对着麦克风说话
      </view>
      
      <view wx:if="{{audioFilePath && !isRecording}}" style="display: flex; flex-direction: column; align-items: center; gap: 10rpx; width: 100%">
        <view style="font-size: 28rpx; color: #2ecc71; padding: 10rpx 20rpx; background-color: #f8fff8; border-radius: 10rpx; width: 100%; text-align: center">
          ✅ 已录制 {{audioDuration}} 秒音频
        </view>
        <button 
          style="background-color: #f0f0f0; color: #666; font-size: 24rpx; padding: 10rpx 20rpx; border: none"
          bindtap="clearAudio">
          清除录音
        </button>
      </view>
    </view>
  </view>

  <view style="background: white; border-radius: 20rpx; padding: 30rpx; margin: 0 30rpx 40rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05)">
    <view style="font-size: 34rpx; margin-bottom: 20rpx; color: #333">📷 添加图片（可选）</view>
    <button 
      style="background-color: #f0f7ff; color: #4A90E2; border: 2rpx solid #4A90E2; border-radius: 10rpx; padding: 15rpx 30rpx; font-size: 28rpx"
      bindtap="chooseImage">
      选择图片
    </button>
    <view wx:if="{{imageList.length > 0}}" style="margin-top: 20rpx">
      <image src="{{imageList[0]}}" style="width: 200rpx; height: 200rpx; border-radius: 10rpx" />
      <button 
        style="background-color: #ffebee; color: #f44336; border: none; margin-top: 10rpx; padding: 10rpx 20rpx; font-size: 24rpx"
        bindtap="removeImage">
        删除图片
      </button>
    </view>
  </view>

  <view wx:if="{{analysisResult}}" style="background: linear-gradient(135deg, #e3f2fd, #f3e5f5); border-radius: 20rpx; padding: 30rpx; margin: 0 30rpx 40rpx; box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.08); border-left: 8rpx solid #3498db">
    <view style="font-size: 36rpx; font-weight: bold; margin-bottom: 30rpx; color: #2c3e50">💡 心灵助手分析结果</view>
    <view style="font-size: 30rpx; margin-bottom: 15rpx; color: #555">您选择的情绪：<text style="font-weight: bold; color: #4A90E2">{{analysisResult.primaryEmotion}}</text></view>
    <view style="font-size: 30rpx; margin-bottom: 15rpx; color: #555">AI识别情绪：<text style="font-weight: bold; color: #e74c3c">{{analysisResult.aiDetectedEmotion}}</text></view>
    <view style="font-size: 30rpx; margin-bottom: 15rpx; color: #555">置信度：{{confidencePercent}}</view>
    <view style="font-size: 30rpx; margin-bottom: 15rpx; color: #555">风险等级：
      <text style="color: {{riskLevelColor}}">{{analysisResult.riskLevel}}</text>
    </view>
    <view style="background-color: white; padding: 25rpx; border-radius: 15rpx; margin-top: 25rpx; border-left: 8rpx solid #3498db; color: #2c3e50; font-size: 28rpx">{{analysisResult.suggestion}}</view>
  </view>
  
  <view style="display: flex; justify-content: space-around; margin: 50rpx 30rpx 30rpx">
    <button style="width: 45%; border-radius: 50rpx; font-size: 32rpx; background-color: #4A90E2; color: white; border: none" bindtap="analyzeMood">立即分析</button>
    <button style="width: 45%; border-radius: 50rpx; font-size: 32rpx; background-color: #9b59b6; color: white; border: none" bindtap="saveRecord">保存记录</button>
  </view>
</view>