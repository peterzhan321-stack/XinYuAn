.container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding: 20rpx;
}

/* 页面标题 */
.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  line-height: 1.4;
}

/* 设置区块 */
.setting-section {
  background-color: white;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  overflow: hidden;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #fafafa;
}

/* 设置项 */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  flex: 1;
  display: flex;
  align-items: center;
}

.setting-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.setting-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-right: 10rpx;
}

.setting-desc {
  font-size: 24rpx;
  color: #999;
  flex: 1;
}

.setting-switch {
  transform: scale(1.2);
}

.setting-btn {
  background-color: #f0f0f0;
  color: #333;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 15rpx;
  border: none;
}

.setting-btn.danger {
  background-color: #ffebee;
  color: #f44336;
}

/* 字体大小滑块 */
.font-size-slider {
  flex: 1;
  display: flex;
  align-items: center;
  margin-left: 30rpx;
}

.font-size-label {
  font-size: 24rpx;
  color: #666;
  margin: 0 10rpx;
}

.slider {
  flex: 1;
}

/* 重置设置 */
.reset-section {
  margin-top: 50rpx;
  margin-bottom: 50rpx;
}

.reset-btn {
  width: 100%;
  height: 80rpx;
  background-color: #f44336;
  color: white;
  font-size: 32rpx;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(244, 67, 54, 0.3);
}

/* 深色模式 */
.container.dark-mode {
  background-color: #121212;
}

.container.dark-mode .setting-section {
  background-color: #1e1e1e;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
}

.container.dark-mode .section-title {
  background-color: #2c2c2c;
  color: #e0e0e0;
  border-bottom: 1rpx solid #333;
}

.container.dark-mode .setting-item {
  border-bottom: 1rpx solid #333;
}

.container.dark-mode .setting-name {
  color: #e0e0e0;
}

.container.dark-mode .setting-desc {
  color: #999;
}

.container.dark-mode .setting-btn {
  background-color: #333;
  color: #e0e0e0;
}

.container.dark-mode .font-size-label {
  color: #999;
}
