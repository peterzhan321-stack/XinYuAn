.container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding: 20rpx;
}

/* 页面标题 */
.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  line-height: 1.4;
}

/* 通用部分标题 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

/* 主题选择 */
.theme-section {
  margin-bottom: 40rpx;
}

.theme-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.theme-item {
  width: calc(33.33% - 14rpx);
  background-color: white;
  border-radius: 15rpx;
  padding: 30rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  transition: all 0.3s ease;
}

.theme-item.selected {
  background: linear-gradient(135deg, #4A90E2, #5C6BC0);
  color: white;
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(74, 144, 226, 0.3);
}

.theme-icon {
  font-size: 50rpx;
  margin-bottom: 15rpx;
}

.theme-icon.large {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.theme-name {
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
}

/* 时间选择 */
.time-section {
  margin-bottom: 40rpx;
}

.time-options {
  display: flex;
  gap: 20rpx;
}

.time-option {
  flex: 1;
  background-color: white;
  border-radius: 15rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  transition: all 0.3s ease;
}

.time-option.selected {
  background: linear-gradient(135deg, #4A90E2, #5C6BC0);
  color: white;
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(74, 144, 226, 0.3);
}

/* 背景音效选择 */
.sound-section {
  margin-bottom: 40rpx;
}

.sound-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.sound-item {
  width: calc(50% - 10rpx);
  background-color: white;
  border-radius: 15rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  transition: all 0.3s ease;
}

.sound-item.selected {
  background: linear-gradient(135deg, #4A90E2, #5C6BC0);
  color: white;
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(74, 144, 226, 0.3);
}

.sound-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.sound-name {
  font-size: 28rpx;
  font-weight: bold;
}

/* 冥想界面 */
.meditation-section {
  margin-bottom: 40rpx;
}

/* 计时器 */
.timer-section {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.timer {
  font-size: 80rpx;
  font-weight: bold;
  color: #4A90E2;
  background-color: white;
  padding: 40rpx 80rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

/* 当前主题 */
.current-theme {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

/* 指导语 */
.instruction-section {
  margin-bottom: 40rpx;
}

.instruction-card {
  background-color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.instruction-content {
  font-size: 32rpx;
  color: #333;
  line-height: 1.5;
  text-align: center;
}

/* 进度环 */
.progress-ring {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.progress-canvas {
  width: 200rpx;
  height: 200rpx;
}

/* 控制按钮 */
.control-section {
  margin-bottom: 40rpx;
}

.primary-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #4A90E2, #5C6BC0);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 226, 0.3);
}

.control-buttons {
  display: flex;
  gap: 20rpx;
}

.secondary-btn {
  flex: 1;
  height: 80rpx;
  background-color: #f0f0f0;
  color: #333;
  font-size: 32rpx;
  border-radius: 40rpx;
  border: none;
}

.danger-btn {
  flex: 1;
  height: 80rpx;
  background-color: #f44336;
  color: white;
  font-size: 32rpx;
  border-radius: 40rpx;
  border: none;
}

/* 练习提示 */
.tips-section {
  background-color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.tips-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

.tips-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  white-space: pre-wrap;
}