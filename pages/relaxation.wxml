<view class="relaxation-container">
  <view class="header">
    <text class="title">放松练习</text>
    <text class="subtitle">选择适合您的放松方式，缓解压力，提升幸福感</text>
  </view>

  <view class="recommendation">
    <text class="section-title">推荐练习</text>
  </view>

  <view class="practice-list">
    <!-- 正念呼吸 -->
    <view class="practice-item" bindtap="goToBreathing">
      <view class="practice-icon" style="background-color: #2196F3;">
        <image src="/images/breathing-icon.png" class="icon-img"></image>
      </view>
      <view class="practice-info">
        <view class="practice-header">
          <text class="practice-name">正念呼吸</text>
          <text class="practice-time">3分钟</text>
        </view>
        <text class="practice-desc">3分钟快速平复情绪，专注当下</text>
      </view>
    </view>

    <!-- 身体扫描 -->
    <view class="practice-item" bindtap="goToBodyScan">
      <view class="practice-icon" style="background-color: #9C27B0;">
        <image src="/images/body-scan-icon.png" class="icon-img"></image>
      </view>
      <view class="practice-info">
        <view class="practice-header">
          <text class="practice-name">身体扫描</text>
          <text class="practice-time">5分钟</text>
        </view>
        <text class="practice-desc">5分钟身体放松，释放紧张</text>
      </view>
    </view>

    <!-- 渐进式肌肉放松 -->
    <view class="practice-item" bindtap="goToMuscleRelaxation">
      <view class="practice-icon" style="background-color: #F44336;">
        <image src="/images/muscle-icon.png" class="icon-img"></image>
      </view>
      <view class="practice-info">
        <view class="practice-header">
          <text class="practice-name">渐进式肌肉放松</text>
          <text class="practice-time">7分钟</text>
        </view>
        <text class="practice-desc">7分钟深度放松，缓解肌肉紧张</text>
      </view>
    </view>

    <!-- 快速冥想 -->
    <view class="practice-item" bindtap="goToQuickMeditation">
      <view class="practice-icon" style="background-color: #4CAF50;">
        <image src="/images/meditation-icon.png" class="icon-img"></image>
      </view>
      <view class="practice-info">
        <view class="practice-header">
          <text class="practice-name">快速冥想</text>
          <text class="practice-time">1分钟</text>
        </view>
        <text class="practice-desc">1分钟快速平静，随时可用</text>
      </view>
    </view>
  </view>
</view>