.relaxation-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  padding: 40rpx 30rpx 20rpx;
  background-color: white;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.4;
}

.recommendation {
  padding: 30rpx 30rpx 20rpx;
  background-color: white;
  margin-top: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.practice-list {
  padding: 0 20rpx 40rpx;
}

.practice-item {
  display: flex;
  align-items: center;
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.practice-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 25rpx;
}

.icon-img {
  width: 50rpx;
  height: 50rpx;
}

.practice-info {
  flex: 1;
}

.practice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.practice-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.practice-time {
  font-size: 26rpx;
  color: #666666;
  background-color: #f0f0f0;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.practice-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.4;
}