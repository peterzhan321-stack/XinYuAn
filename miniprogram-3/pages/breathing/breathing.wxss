.breathing-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 30rpx 20rpx;
  position: relative;
}

.title-section {
  display: flex;
  flex-direction: column;
}

.main-title {
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
  color: #ffffff;
}

.sub-title {
  font-size: 24rpx;
  opacity: 0.85;
  color: rgba(255, 255, 255, 0.9);
}

.close-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 300;
  color: #ffffff;
}

.close-btn:active {
  background: rgba(255, 255, 255, 0.3);
}

.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 30rpx 40rpx;
}

.breathing-animation {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 40rpx 0 60rpx;
}

.circle-container {
  width: 500rpx;
  height: 500rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.outer-circle {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 1s cubic-bezier(0.4, 0, 0.2, 1);
}

.middle-circle {
  width: 80%;
  height: 80%;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  border: 3rpx solid rgba(255, 255, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 1s cubic-bezier(0.4, 0, 0.2, 1);
}

.inner-circle {
  width: 60%;
  height: 60%;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 1s cubic-bezier(0.4, 0, 0.2, 1);
}

.breath-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.time-text {
  font-size: 28rpx;
  opacity: 0.9;
  color: rgba(255, 255, 255, 0.9);
}

.instruction-text {
  margin-top: 40rpx;
  text-align: center;
  font-size: 28rpx;
  opacity: 0.9;
  color: rgba(255, 255, 255, 0.9);
  padding: 0 30rpx;
  line-height: 1.5;
}

.stats-section {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 40rpx;
  backdrop-filter: blur(10rpx);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.8;
  margin-bottom: 10rpx;
  color: rgba(255, 255, 255, 0.9);
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

.controls-section {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  backdrop-filter: blur(10rpx);
}

.breath-rhythm {
  margin-bottom: 30rpx;
}

.rhythm-label {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  display: block;
  color: #ffffff;
}

.rhythm-options {
  display: flex;
  gap: 20rpx;
}

.rhythm-option {
  flex: 1;
  padding: 20rpx 0;
  text-align: center;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.rhythm-option:active {
  background: rgba(255, 255, 255, 0.2);
}

.rhythm-option.active {
  background: rgba(255, 255, 255, 0.2);
  border-color: rgba(255, 255, 255, 0.5);
  color: #ffffff;
  font-weight: 600;
}

.control-buttons {
  margin-top: 10rpx;
}

.button-group {
  display: flex;
  gap: 20rpx;
}

.control-button {
  flex: 1;
  padding: 28rpx 0;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.start-button {
  background: linear-gradient(135deg, #4CAF50 0%, #8BC34A 100%);
  color: #ffffff;
}

.start-button:active {
  background: linear-gradient(135deg, #43A047 0%, #7CB342 100%);
  transform: translateY(2rpx);
}

.start-button.active {
  background: linear-gradient(135deg, #FF9800 0%, #FF5722 100%);
}

.reset-button {
  background: rgba(255, 255, 255, 0.15);
  color: #ffffff;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.reset-button:active {
  background: rgba(255, 255, 255, 0.25);
  transform: translateY(2rpx);
}

.guide-section {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 30rpx;
  backdrop-filter: blur(10rpx);
}

.guide-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 25rpx;
  color: #ffffff;
  display: block;
}

.guide-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.guide-item {
  display: flex;
  align-items: flex-start;
  gap: 15rpx;
}

.guide-number {
  width: 40rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.guide-text {
  font-size: 26rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.9);
  flex: 1;
}